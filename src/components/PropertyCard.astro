---
import { Image } from 'astro:assets'; //
const { address, price, status, image, url } = Astro.props;
---
<div class="group relative animate-reveal">
  <a href={url} class="block">
    <!-- Rounded Frame to match Homepage -->
    <div class="relative aspect-[4/5] overflow-hidden rounded-[2.5rem] bg-slate-100 shadow-lg">
      <img 
        src={image || '/images/placeholder.jpg'} 
        alt={address} 
        class="w-full h-full object-cover grayscale transition-all duration-700 group-hover:grayscale-0 group-hover:scale-110"
      />
      
      <!-- Subtle Overlay for text legibility -->
      <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-80"></div>
      
      <!-- Text Info Floating at the Bottom -->
      <div class="absolute bottom-8 left-8 right-8 text-white">
        <span class="text-[10px] uppercase tracking-[0.3em] font-bold text-white/70 mb-2 block">{status}</span>
        <h3 class="text-2xl font-serif leading-tight">{address}</h3>
        <p class="text-sm font-light text-white/90 mt-2 tracking-widest">{price}</p>
      </div>
    </div>
  </a>
</div>

