---
import { Image } from 'astro:assets';
const { address, price, status, image, url } = Astro.props;
---

<!-- 1. Start at opacity-0 so there is no "flash" before animation -->
<div class="group relative opacity-0 transform-gpu transition-all duration-1000 translate-y-4" data-property-card>
  <a href={url} class="block">
    <div class="relative aspect-[4/5] overflow-hidden rounded-[2.5rem] md:rounded-[3rem] bg-slate-100 shadow-lg">
      
      {image ? (
        <Image 
          src={image} 
          alt="" 
          width={800} 
          height={1000}
          /* 2. Added object-fit & aspect-ratio directly to stop the snap */
          class="w-full h-full object-cover aspect-[4/5] grayscale transition-all duration-700 ease-out group-hover:grayscale-0 group-hover:scale-105 transform-gpu will-change-transform"
          loading="eager"
        />
      ) : (
        <div class="w-full h-full bg-gradient-to-br from-gray-100 to-gray-300"></div>
      )}
      
      <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent opacity-90 transition-opacity duration-700 group-hover:opacity-70"></div>
      
      <div class="absolute bottom-10 left-8 right-8 text-white transform transition-transform duration-700 ease-out group-hover:-translate-y-2 will-change-transform">
        <span class="text-[10px] uppercase tracking-[0.4em] font-bold text-white/50 mb-3 block transform-gpu">
          {status}
        </span>
        <h3 class="text-2xl md:text-3xl font-serif leading-tight subpixel-antialiased">
          {address}
        </h3>
        <p class="text-[11px] font-light text-white/80 mt-4 tracking-[0.2em] uppercase border-t border-white/10 pt-4">
          {price}
        </p>
      </div>
    </div>
  </a>
</div>

<script is:inline>
  /**
   * BACK-BUTTON REVEAL LOGIC
   * This script runs immediately on every page visit, even from cache.
   */
  function revealCards() {
    const cards = document.querySelectorAll('[data-property-card]');
    cards.forEach((card, index) => {
      setTimeout(() => {
        card.style.opacity = "1";
        card.style.transform = "translateY(0)";
      }, index * 100); // Staggered entrance for luxury feel
    });
  }

  // Handle both standard loads and the "Back" button (pageshow)
  window.addEventListener('pageshow', revealCards);
  document.addEventListener('astro:page-load', revealCards);
</script>







