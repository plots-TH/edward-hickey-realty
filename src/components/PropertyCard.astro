---
import { Image } from 'astro:assets';
const { address, price, status, image, url } = Astro.props;
---

<div class="group relative animate-reveal transform-gpu will-change-transform">
  <a href={url} class="block">
    <!-- The Frame -->
    <div class="relative aspect-[4/5] overflow-hidden rounded-[2rem] md:rounded-[3rem] bg-slate-100 shadow-lg">

      {image ? (
        <Image 
          src={image} 
          alt="" 
          width={800} 
          height={1000}
          class="w-full h-full object-cover grayscale transition-all duration-700 ease-out group-hover:grayscale-0 group-hover:scale-105 transform-gpu will-change-transform"
        />
      ) : (
        /* Sleek Placeholder for posts without images */
        <div class="w-full h-full bg-gradient-to-br from-gray-50 to-gray-200 flex items-center justify-center">
          <span class="text-[10px] uppercase tracking-[0.3em] text-gray-400 font-light italic">Image Coming Soon</span>
        </div>
      )}

      <!-- Subtle Overlay -->
      <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent opacity-80 transition-opacity duration-700 group-hover:opacity-60"></div>
      
      <!-- Text Info remains the same... -->
    </div>
  </a>
</div>



