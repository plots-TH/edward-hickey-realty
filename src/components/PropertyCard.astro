---
import { Image } from 'astro:assets'; //
const { address, price, status, image, url } = Astro.props;
---
<div class="group border border-gray-100 hover:shadow-xl transition-shadow">
  <a href={url} class="block">
    <div class="aspect-video overflow-hidden bg-gray-100 relative">
      {image ? (
        <Image 
          src={image} 
          alt={`Luxury property at ${address}`}
          width={800} 
          height={450}
          format="webp"
          class="w-full h-full object-cover transition-transform group-hover:scale-105"
        />
      ) : (
        <div class="w-full h-full flex items-center justify-center bg-gray-200">No Image</div>
      )}
      <div class="absolute top-4 left-4 bg-white/90 px-3 py-1 text-[10px] uppercase tracking-widest font-semibold">
        {status}
      </div>
    </div>
    <div class="p-6">
      <h3 class="text-lg font-serif text-gray-900">{address}</h3>
      <p class="text-gray-600 mt-1 font-medium">{price}</p>
    </div>
  </a>
</div>

