---
const today = new Date();
---

<footer>
  <div class="footer-content">
    <p>&copy; {today.getFullYear()} Edward Hickey. All rights reserved.</p>
    <p class="agency">Licensed Associate Real Estate Broker | Compass</p>
    
    <div class="social-links">
      <!-- LinkedIn -->
      <a href="https://www.linkedin.com/in/edward-hickey-50612445/" target="_blank" rel="noopener noreferrer">
        <span class="sr-only">Follow Edward on LinkedIn</span>
        <svg viewBox="0 0 24 24" aria-hidden="true" width="24" height="24" fill="currentColor">
          <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" />
        </svg>
      </a>

      <!-- Instagram -->
      <a href="https://www.instagram.com/ed_hickey_compass/" target="_blank" rel="noopener noreferrer">
        <span class="sr-only">Follow Edward on Instagram</span>
        <svg viewBox="0 0 24 24" aria-hidden="true" width="24" height="24" fill="currentColor">
          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z" />
        </svg>
      </a>
    </div>

    <!-- Corrected Admin Login Button -->
    <div class="mt-12">
      <button 
        id="admin-login-btn"
        class="bg-white border border-gray-200 text-gray-400 px-6 py-2 rounded-full text-[10px] uppercase tracking-widest hover:text-black hover:border-black transition-all cursor-pointer"
      >
        Admin Access
      </button>
    </div>
  </div>
</footer>

<script is:inline>
  const loginBtn = document.getElementById('admin-login-btn');

  if (loginBtn) {
    loginBtn.addEventListener('click', () => {
      if (window.netlifyIdentity) {
        window.netlifyIdentity.open("login");
      } else {
        console.error("Netlify Identity not loaded");
        alert("Admin module loading... please try again in a moment.");
      }
    });
  }
</script>

<style>
  footer {
    padding: 6em 1em;
    background: #ffffff;
    color: #1e293b;
    text-align: center;
    border-top: 1px solid #f1f5f9;
  }
  .footer-content {
    max-width: 80rem;
    margin: 0 auto;
  }
  .footer-content p {
    font-size: 0.9rem;
    color: #64748b;
  }
  .agency {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-top: 0.5em;
    color: #94a3b8 !important;
  }
  .social-links {
    display: flex;
    justify-content: center;
    gap: 2em;
    margin-top: 2.5em;
  }
  .social-links a {
    text-decoration: none;
    color: #94a3b8;
    transition: all 0.3s ease;
  }
  .social-links a:hover {
    color: #0f172a;
    transform: translateY(-2px);
  }
</style>



