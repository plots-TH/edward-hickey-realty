---
// Clean slate - No imports needed for now
---
<header class="bg-white border-b border-gray-100 sticky top-0 z-50">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between h-20 items-center">
      
      <!-- Brand/Logo Area -->
      <div class="flex-shrink-0 flex items-center space-x-4">
        <a href="/" class="text-2xl font-bold tracking-tight text-slate-900">
          EDWARD <span class="font-light text-[#b89146]">HICKEY</span>
        </a>
        
        <!-- Vertical Divider -->
        <div class="h-6 w-px bg-gray-200 hidden sm:block"></div>
        
        <!-- Compass Official Link -->
        <a href="https://www.compass.com/agents/edward-hickey/" target="_blank" class="hidden sm:block hover:opacity-70 transition-opacity">
          <img 
            src="https://wikimedia.org" 
            alt="Compass" 
            class="h-3"
          />
        </a>
      </div>

      <!-- Main Navigation Links -->
      <div class="hidden md:flex space-x-8 items-center">
        <a href="/" class="text-xs uppercase tracking-widest font-medium text-gray-600 hover:text-black transition">Home</a>
        <a href="/listings" class="text-xs uppercase tracking-widest font-medium text-gray-600 hover:text-black transition">Listings</a>
        <a href="/closed" class="text-xs uppercase tracking-widest font-medium text-gray-600 hover:text-black transition">Recently Sold</a>
        <a href="/blog" class="text-xs uppercase tracking-widest font-medium text-gray-600 hover:text-black transition">Market Insights</a>
        <a href="/contact" class="bg-slate-900 text-white px-6 py-2.5 text-xs uppercase tracking-[0.2em] font-semibold hover:bg-slate-800 transition shadow-sm">
          Contact
        </a>
      </div>
      
    </div>
  </nav>
</header>


