---
// Clean slate - No imports needed for now
---
<header class="bg-white border-b border-gray-50 sticky top-0 z-50">
  <nav class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="flex justify-between h-24 items-center">
      
      <!-- Brand/Logo Area -->
      <div class="flex-shrink-0 flex items-center space-x-4">
        <a href="/" class="text-2xl font-bold tracking-tight text-black">
          EDWARD <span class="font-light text-gray-400">HICKEY</span>
        </a>
        <div class="h-6 w-px bg-gray-200 hidden sm:block"></div>
        <a href="https://compass.com" target="_blank" class="hidden sm:flex hover:opacity-40 transition-opacity">
          <img src="https://wikimedia.org" alt="Compass" class="h-[12px] brightness-0" />
        </a>
      </div>

      <!-- Navigation Links -->
      <div class="hidden md:flex space-x-10 items-center">
        <a href="/listings" class="text-[10px] uppercase tracking-[0.2em] font-bold text-gray-400 hover:text-black transition">Listings</a>
        <a href="/closed" class="text-[10px] uppercase tracking-[0.2em] font-bold text-gray-400 hover:text-black transition">Recently Sold</a>
        <a href="/blog" class="text-[10px] uppercase tracking-[0.2em] font-bold text-gray-400 hover:text-black transition">Insights</a>
        <a href="/contact" class="bg-black text-white px-8 py-3 rounded-full text-[10px] uppercase tracking-[0.2em] font-bold hover:bg-gray-800 transition shadow-sm">
          Inquire
        </a>
      </div>
      
    </div>
  </nav>
</header>



