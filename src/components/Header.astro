---
// Clean slate - No imports needed for now
---
<header class="bg-white border-b border-gray-50 sticky top-0 z-50">
  <nav class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="flex justify-between h-24 items-center">
      
      <!-- Brand/Logo Area -->
      <div class="flex-shrink-0 flex items-center space-x-4">
        <!-- Edward Hickey Link -->
        <a href="/" class="text-2xl font-bold tracking-tight text-black transition-all duration-500 hover:scale-105 hover:opacity-70 block">
          EDWARD <span class="font-light text-gray-400">HICKEY</span>
        </a>
        
        <div class="h-6 w-px bg-gray-200 hidden sm:block"></div>
        
        <!-- Compass Link -->
        <a href="https://compass.com" target="_blank" class="hidden sm:flex items-center transition-all duration-500 hover:scale-110 hover:opacity-60">
          <img src="https://wikimedia.org" alt="Compass" class="h-[12px] brightness-0" />
        </a>
      </div>

      <!-- Navigation Links -->
      <div class="hidden md:flex space-x-10 items-center">
        <!-- Normal Links -->
        {['About', 'Listings', 'Recently Sold', 'Insights'].map((link) => (
          <a 
            href={`/${link.toLowerCase().replace(' ', '')}`} 
            class="text-[10px] uppercase tracking-[0.2em] font-bold text-gray-400 transition-all duration-500 hover:text-black hover:scale-110 block"
          >
            {link}
          </a>
        ))}
        
        <!-- Inquire Button -->
        <a href="/contact" class="bg-black text-white px-8 py-3 rounded-full text-[10px] uppercase tracking-[0.2em] font-bold transition-all duration-500 hover:bg-gray-800 hover:scale-105 hover:shadow-lg active:scale-95">
          Inquire
        </a>
      </div>
      
    </div>
  </nav>
</header>




