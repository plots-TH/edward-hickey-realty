---
// Header.astro
---
<header class="bg-white border-b border-gray-50 sticky top-0 z-50">
  <nav class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="flex justify-between h-24 items-center">
      <div class="flex-shrink-0 flex items-center space-x-4">
        <a href="/" class="text-2xl font-bold tracking-tight text-black transition-all duration-500 hover:scale-105">
          EDWARD <span class="font-light text-gray-400">HICKEY</span>
        </a>
      </div>

      <div class="hidden md:flex space-x-10 items-center">
        <a id="admin-nav-link" href="/admin/" class="hidden text-[10px] uppercase tracking-[0.2em] font-bold text-slate-900 border-b border-slate-900">Admin</a>
        <a href="/about" class="text-[10px] uppercase tracking-[0.2em] font-bold text-gray-400 hover:text-black transition">About</a>
        <a href="/listings" class="text-[10px] uppercase tracking-[0.2em] font-bold text-gray-400 hover:text-black transition">Listings</a>
        <a href="/closed" class="text-[10px] uppercase tracking-[0.2em] font-bold text-gray-400 hover:text-black transition">Recently Sold</a>
        <a href="/contact" class="bg-black text-white px-8 py-3 rounded-full text-[10px] uppercase tracking-[0.2em] font-bold hover:bg-gray-800 transition">Inquire</a>
      </div>
    </div>
  </nav>
</header>

<script is:inline>
  function toggleAdminLink() {
    const adminLink = document.getElementById("admin-nav-link");
    if (!adminLink || !window.netlifyIdentity) return;

    const user = window.netlifyIdentity.currentUser();
    adminLink.classList.toggle("hidden", !user);
  }

  function initAdminLink() {
    if (!window.netlifyIdentity) return;

    toggleAdminLink();

    if (!window.__adminLinkListenersBound) {
      window.__adminLinkListenersBound = true;

      window.netlifyIdentity.on("init", toggleAdminLink);
      window.netlifyIdentity.on("login", toggleAdminLink);
      window.netlifyIdentity.on("logout", toggleAdminLink);
    }
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initAdminLink);
  } else {
    initAdminLink();
  }

  document.addEventListener("astro:page-load", initAdminLink);
</script>








