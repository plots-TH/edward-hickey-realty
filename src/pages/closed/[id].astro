---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

// This function is REQUIRED for [id].astro files
export async function getStaticPaths() {
  const closedListings = await getCollection('closed');
  return closedListings.map((item) => ({
    params: { id: item.id },
    props: { item },
  }));
}

const { item } = Astro.props;
const { Content } = await render(item);
---

<BaseLayout title={`${item.data.address} | Recently Sold | Edward Hickey`}>
  <article class="py-20 px-6 max-w-5xl mx-auto">
    <div class="mb-12 border-b border-gray-100 pb-8">
      <span class="text-gold-600 uppercase tracking-widest text-sm font-semibold">Sold</span>
      <h1 class="text-5xl font-serif text-gray-900 mt-2 mb-4">{item.data.address}</h1>
      <p class="text-2xl text-gray-600">Sale Price: {item.data.salePrice}</p>
    </div>

    <div class="aspect-video overflow-hidden bg-gray-100 mb-12 shadow-lg">
       <img src={item.data.heroImage} alt={item.data.address} class="w-full h-full object-cover" />
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
      <div class="lg:col-span-2 prose prose-lg max-w-none">
        <Content />
      </div>
      
      <div class="bg-gray-50 p-8 rounded-sm h-fit">
        <h3 class="text-xl font-serif mb-4 text-gray-900">Market Analysis</h3>
        <p class="text-gray-600 text-sm mb-6">Interested in the current value of your property? Contact Edward for a bespoke valuation.</p>
        <a href="/contact" class="block w-full bg-navy-900 text-white text-center py-4 uppercase tracking-widest text-sm font-semibold hover:bg-navy-800 transition">
          Request Valuation
        </a>
      </div>
    </div>
  </article>
</BaseLayout>


