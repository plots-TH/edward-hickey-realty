---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PropertyCard from '../../components/PropertyCard.astro';

const allClosed = await getCollection('closed');
---

<BaseLayout title="Recently Sold | Edward Hickey">
  <section class="py-20 px-6 max-w-7xl mx-auto min-h-screen">
    <h1 class="text-5xl font-serif mb-12">Recently Sold</h1>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {allClosed.length > 0 ? (
        allClosed.map((item) => (
          <PropertyCard 
            address={item.data.address}
            price={item.data.salePrice}
            status="Sold"
            image={item.data.heroImage}
            url={`/closed/${item.id}`} 
          />
        ))
      ) : (
        <p class="text-gray-500 italic text-center py-20 border border-dashed border-gray-200">
          Historical data arriving shortly.
        </p>
      )}
    </div>
  </section>
</BaseLayout>

