---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Contact Edward Hickey">
  <section class="py-20 px-6 max-w-3xl mx-auto">
    <h1 class="text-4xl font-serif mb-8">Inquiry</h1>
    <form name="contact" method="POST" data-netlify="true" class="grid grid-cols-1 gap-6">
      <input type="hidden" name="form-name" value="contact" />
      <div>
        <label class="block text-sm font-medium text-gray-700">Name</label>
        <input type="text" name="name" class="mt-1 block w-full border border-gray-300 p-3 rounded-md" required />
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700">Email</label>
        <input type="email" name="email" class="mt-1 block w-full border border-gray-300 p-3 rounded-md" required />
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700">Message</label>
        <textarea name="message" rows="4" class="mt-1 block w-full border border-gray-300 p-3 rounded-md"></textarea>
      </div>
      <button type="submit" class="bg-navy-900 text-white py-4 px-8 hover:bg-navy-800 transition">Send Message</button>
    </form>
  </section>
</BaseLayout>
