---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found | Edward Hickey">
  <section class="flex flex-col items-center justify-center min-h-[70vh] text-center px-6">
    <h1 class="text-7xl font-serif text-slate-200 mb-4">404</h1>
    <h2 class="text-2xl font-serif mb-6">Page Not Found</h2>
    <p class="text-gray-600 mb-10 max-w-md">
      The page you are looking for may have been moved or is no longer available.
    </p>
    <a href="/" class="border border-slate-900 px-8 py-3 text-xs uppercase tracking-widest font-semibold hover:bg-slate-900 hover:text-white transition">
      Return to Portfolio
    </a>
  </section>
</BaseLayout>
