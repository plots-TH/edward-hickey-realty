---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PropertyCard from '../components/PropertyCard.astro';

const allListings = await getCollection('listings');
---

<BaseLayout title="Active Portfolio | Edward Hickey">
  <section class="py-20 px-6 max-w-7xl mx-auto min-h-screen">
    <h1 class="text-5xl font-serif mb-12">Active Portfolio</h1>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {allListings.length > 0 ? (
        allListings.map((item) => (
            <PropertyCard 
                address={item.data.address}
                price={item.data.price}
                status={item.data.status}
                image={item.data.heroImage}
                url={`/listings/${item.id || item.slug}`} 
        />
        ))
      ) : (
        <p class="text-gray-500 italic">No active listings at this time. Please check back soon.</p>
      )}
    </div>
  </section>
</BaseLayout>



