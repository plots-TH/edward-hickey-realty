---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Edward Hickey | Real Estate">
  <!-- Hero Container -->
  <section class="bg-white py-12 md:py-20 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      
      <!-- The Frame -->
      <div class="relative h-[70vh] md:h-[85vh] w-full overflow-hidden rounded-[2rem] md:rounded-[4rem] bg-slate-100 shadow-2xl animate-reveal">
        
        <!-- Image with subtle zoom -->
        <img 
          src="/images/hero-bg.jpg" 
          alt="Manhattan Luxury" 
          class="w-full h-full object-cover grayscale brightness-75 transition-transform duration-[3000ms] hover:scale-105"
        />

        <!-- Overlay Text -->
        <div class="absolute inset-0 flex flex-col items-center justify-center text-center p-6 bg-black/20">
          <span class="text-white/80 uppercase tracking-[0.4em] text-[10px] md:text-xs mb-6 animate-reveal delay-1">
            Manhattan • Brooklyn • The Hamptons
          </span>
          
          <h1 class="text-white text-5xl md:text-8xl font-serif mb-10 leading-[1.1] animate-reveal delay-2">
            Modern Luxury <br /> 
            <span class="font-light italic text-white/90">Defined</span>
          </h1>

          <div class="flex flex-col sm:flex-row gap-6 animate-reveal delay-2" style="animation-delay: 0.6s;">
            <a href="/listings" class="bg-white text-black px-12 py-4 text-[10px] uppercase tracking-[0.2em] font-bold hover:bg-black hover:text-white transition-all duration-500 rounded-full">
              Explore Portfolio
            </a>
            <a href="/contact" class="backdrop-blur-md bg-white/10 border border-white/30 text-white px-12 py-4 text-[10px] uppercase tracking-[0.2em] font-bold hover:bg-white hover:text-black transition-all duration-500 rounded-full">
              Private Inquiry
            </a>
          </div>
        </div>
      </div>
      
    </div>
  </section>
</BaseLayout>




