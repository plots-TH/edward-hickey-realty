---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PropertyCard from '../components/PropertyCard.astro';

// Fetch the closed collection
const soldProperties = await getCollection('closed');
---

<BaseLayout title="Recently Sold | Edward Hickey">
  <section class="py-20 px-6 max-w-7xl mx-auto min-h-screen">
    
    <!-- Header with Reveal Animation -->
    <div class="mb-16 border-b border-gray-100 pb-8 animate-reveal">
      <span class="text-[10px] uppercase tracking-[0.4em] font-bold text-gray-400 mb-4 block">Archive</span>
      <h1 class="text-5xl md:text-6xl font-serif text-gray-900 mb-4">Recently Sold</h1>
      <p class="text-gray-500 font-light italic tracking-wide">A legacy of successful transactions across Manhattan.</p>
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12">
      {soldProperties.length > 0 ? (
        soldProperties.map((post) => (
          <PropertyCard 
            address={post.data.address}
            price={`Sold for ${post.data.salePrice}`}
            status="Sold" 
            image={post.data.heroImage}
            url={`/closed/${post.id}`} 
          />
        ))
      ) : (
        <p class="text-gray-400 italic py-20 animate-reveal delay-1">New transaction data arriving shortly.</p>
      )}
    </div>
  </section>
</BaseLayout>



