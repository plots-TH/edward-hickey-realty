---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

import 'swiper/css';
import 'swiper/css/navigation';
import 'swiper/css/pagination';

export async function getStaticPaths() {
  const listings = await getCollection('listings');
  return listings.map((item) => ({
    params: { id: item.id },
    props: { item },
  }));
}

const { item } = Astro.props;
const { Content } = await render(item);

const allImages = [item.data.heroImage, ...(item.data.gallery || [])].filter(Boolean);
---

<BaseLayout title={`${item.data.address} | Edward Hickey`}>
  <article class="py-20 px-6 max-w-6xl mx-auto animate-reveal">
    <div class="text-center mb-16">
      <span class="text-[10px] uppercase tracking-[0.4em] font-bold text-gray-400 mb-4 block">
        {item.data.status || 'Recently Sold'}
      </span>
      <h1 class="text-5xl md:text-7xl font-serif text-gray-900 mb-6">{item.data.address}</h1>
      <p class="text-xl md:text-2xl font-light text-gray-500 tracking-widest uppercase">
        {item.data.price || `Sold for ${item.data.price}`}
      </p>
    </div>

    <div class="swiper property-carousel rounded-[2rem] md:rounded-[4rem] shadow-2xl mb-20 bg-slate-50 overflow-hidden h-[50vh] md:h-[75vh]">
      <div class="swiper-wrapper">
        {allImages.map((img) => (
          <div class="swiper-slide">
            <img
              src={img}
              alt={item.data.address}
              class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-1000"
            />
          </div>
        ))}
      </div>

      <div class="swiper-button-next !text-white !opacity-40 hover:!opacity-100 transition"></div>
      <div class="swiper-button-prev !text-white !opacity-40 hover:!opacity-100 transition"></div>
      <div class="swiper-pagination"></div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-16">
      <div class="lg:col-span-2 prose prose-slate prose-lg max-w-none font-light text-gray-600 leading-relaxed">
        <Content />
      </div>

      <aside class="h-fit sticky top-32">
        <div class="border border-gray-100 p-10 rounded-[2rem] bg-white shadow-sm text-center">
          <h3 class="text-xl font-serif mb-4">Inquire</h3>
          <p class="text-sm text-gray-500 mb-8 font-light italic">Request a private showing or detailed market analysis for this property.</p>
          <a
            href="/contact"
            onclick="event.preventDefault(); window.trackLeadEvent('generate_lead', { type: 'listing_inquiry_click', destination: '/contact' }); setTimeout(() => { window.location.href='/contact'; }, 150);"
            class="block w-full bg-black text-white py-4 rounded-full text-[10px] uppercase tracking-[0.2em] font-bold hover:bg-gray-800 transition transform-gpu hover:scale-105"
          >
            Contact Edward
          </a>
        </div>
      </aside>
    </div>
  </article>
</BaseLayout>

<script>
  import Swiper from 'swiper';
  import { Navigation, Pagination, Autoplay } from 'swiper/modules';

  function initSwiper() {
    new Swiper('.property-carousel', {
      modules: [Navigation, Pagination, Autoplay],
      loop: true,
      speed: 1200,
      autoplay: { delay: 5000, disableOnInteraction: false },
      navigation: { nextEl: '.swiper-button-next', prevEl: '.swiper-button-prev' },
      pagination: { el: '.swiper-pagination', clickable: true },
    });
  }

  document.addEventListener('astro:page-load', initSwiper);
  document.addEventListener('DOMContentLoaded', initSwiper);
</script>

<style>
  :global(.swiper-pagination-bullet) { background: #fff; opacity: 0.5; }
  :global(.swiper-pagination-bullet-active) { background: #fff; opacity: 1; }
</style>




