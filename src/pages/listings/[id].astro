---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const listings = await getCollection('listings');
  return listings.map((item) => ({
    params: { id: item.id },
    props: { item },
  }));
}

const { item } = Astro.props;
const { Content } = await render(item);
---

<BaseLayout title={`${item.data.address} | Edward Hickey`}>
  <article class="py-20 px-6 max-w-5xl mx-auto">
    <div class="mb-12 border-b border-gray-100 pb-8 text-center">
      <span class="text-[#b89146] uppercase tracking-widest text-sm font-semibold">{item.data.status}</span>
      <h1 class="text-5xl font-serif text-gray-900 mt-2 mb-4">{item.data.address}</h1>
      <p class="text-2xl text-gray-600 font-light">{item.data.price}</p>
    </div>

    <div class="aspect-[21/9] overflow-hidden bg-gray-100 mb-12 shadow-2xl">
      {item.data.heroImage && (
        <Image 
          src={item.data.heroImage} 
          alt={item.data.address}
          width={1920}
          height={822}
          format="webp"
          quality="high"
          class="w-full h-full object-cover"
        />
      )}
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
      <div class="lg:col-span-2 prose prose-lg max-w-none">
        <Content />
      </div>
      <div class="bg-gray-50 p-8 h-fit sticky top-28">
        <h3 class="text-xl font-serif mb-4">Private Showing</h3>
        <p class="text-gray-600 text-sm mb-6 font-light italic">Experience bespoke Manhattan luxury.</p>
        <a href="/contact" class="block w-full bg-slate-900 text-white text-center py-4 uppercase tracking-widest text-xs font-semibold hover:bg-slate-800 transition">
          Inquire Now
        </a>
      </div>
    </div>
  </article>
</BaseLayout>

