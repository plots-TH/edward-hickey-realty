---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FormattedDate from '../../components/FormattedDate.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout title="Market Insights | Edward Hickey">
	<section class="py-20 px-6 max-w-7xl mx-auto min-h-screen">
		<div class="mb-16 border-b border-gray-100 pb-8">
			<h1 class="text-5xl font-serif text-gray-900 mb-4">Market Insights</h1>
			<p class="text-gray-500 uppercase tracking-widest text-sm">Manhattan Real Estate Analysis</p>
		</div>

		<div class="grid grid-cols-1 md:grid-cols-2 gap-12">
			{posts.map((post) => (
				<article class="group">
					<a href={`/blog/${post.id}/`}>
						<img width={720} height={360} src={post.data.heroImage} alt="" class="mb-4 shadow-sm group-hover:shadow-md transition-shadow" />
						<h4 class="text-2xl font-serif text-gray-900 group-hover:text-gray-600 transition-colors mb-2">{post.data.title}</h4>
						<p class="text-gray-500 mb-4">
							<FormattedDate date={post.data.pubDate} />
						</p>
					</a>
				</article>
			))}
		</div>
	</section>
</BaseLayout>

