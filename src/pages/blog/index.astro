---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PropertyCard from '../../components/PropertyCard.astro';

const posts = await getCollection('blog');
---

<BaseLayout title="Market Insights | Edward Hickey">
  <section class="py-20 px-6 max-w-7xl mx-auto min-h-screen">
    <div class="mb-16 border-b border-gray-100 pb-8 animate-reveal">
      <span class="text-[10px] uppercase tracking-[0.4em] font-bold text-gray-400 mb-4 block">Analysis</span>
      <h1 class="text-5xl md:text-6xl font-serif text-gray-900 mb-4">Market Insights</h1>
      <p class="text-gray-500 font-light italic tracking-wide">Expert perspectives on the New York real estate landscape.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12">
      {posts.map((post) => (
        <PropertyCard 
          address={post.data.title}
          price={post.data.description}
          status="Article" 
          image={post.data.heroImage}
          url={`/blog/${post.id}`} 
        />
      ))}
    </div>
  </section>
</BaseLayout>


