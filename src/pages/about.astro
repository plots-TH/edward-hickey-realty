---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About Edward Hickey | Luxury Manhattan Real Estate">
  <section class="bg-white py-24 px-6 md:px-12 lg:px-24">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      
      <!-- Image Side -->
      <div class="relative animate-reveal">
        <div class="rounded-[2.5rem] overflow-hidden bg-slate-100 shadow-2xl aspect-[4/5]">
          <img 
            src="/images/edward_headshot.jpg" 
            alt="Edward Hickey" 
            class="w-full h-full object-cover grayscale brightness-90 hover:grayscale-0 transition-all duration-700"
          />
        </div>
        <div class="absolute -bottom-6 -right-6 h-32 w-32 border-b-2 border-r-2 border-gray-200 rounded-br-[2.5rem] hidden md:block"></div>
      </div>

      <!-- Text Side -->
      <div class="animate-reveal delay-1">
        <span class="text-[10px] uppercase tracking-[0.4em] font-bold text-gray-400 mb-6 block">The Broker</span>
        <h2 class="text-4xl md:text-6xl font-serif text-black mb-8 leading-tight">
          A Native New Yorker <br /> 
          <span class="italic font-light">With Over 30 Years of Insight</span>
        </h2>
        
        <div class="space-y-6 text-gray-600 leading-relaxed font-light text-lg">
          <p>
            Since 1991, Edward Hickey has been a pillar of the New York real estate community. As a native New Yorker with over 32 years of experience and hundreds of millions in closed sales, he offers encyclopedic market knowledge across NYC and Westchester County.
          </p>
          <p>
            Specializing in the unique world of Downtown A.I.R. Lofts in Soho, Tribeca, and Noho, as well as high-end Co-ops on the Upper East and West Sides, Edward blends his award-winning background in photography with deep technical expertise to market Manhattan's most exclusive properties.
          </p>
          <p>
            An avid swimmer and supporter of Swim Across America, Edward brings the same dedication to his philanthropy—fundraising for cancer research—as he does to navigating clients through New York's complex purchase processes.
          </p>
        </div>

        <div class="mt-12 flex items-center space-x-8">
          <div class="text-center">
            <span class="block text-3xl font-serif text-black">Hundreds of Millions</span>
            <span class="text-[10px] uppercase tracking-widest text-gray-400">Total Sales</span>
          </div>
          <div class="h-10 w-px bg-gray-200"></div>
          <div class="text-center">
            <span class="block text-3xl font-serif text-black">32+</span>
            <span class="text-[10px] uppercase tracking-widest text-gray-400">Years Experience</span>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
