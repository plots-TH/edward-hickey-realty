---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { ClientRouter } from 'astro:transitions';

const { title = "Edward Hickey | Real Estate" } = Astro.props;
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title}</title>

		<!-- 1. The ONLY library call - no extra logic here -->
		<script is:inline src="/netlify-identity.js"></script>

		<ClientRouter />

		<!-- SEO & Favicon -->
		<meta name="description" content="Edward Hickey - Luxury Real Estate Associate Broker at Compass." />
		<link rel="icon" type="image/png" href="/favicon.png" />
	</head>
	<body class="bg-white text-slate-900 flex flex-col min-h-screen">
		<Header />
		<main class="flex-grow">
			<slot />
		</main>
		<Footer />

		<!-- 2. The script that FORCES the signup box to open -->
		<script is:inline>
  function handleIdentity() {
    if (window.netlifyIdentity) {
      // 1. Handle the Initial Invite/Signup
      if (window.location.hash.includes("invite_token")) {
        const checkIdentity = setInterval(() => {
          if (window.netlifyIdentity) {
            window.netlifyIdentity.open("signup");
            clearInterval(checkIdentity);
          }
        }, 500);
        setTimeout(() => clearInterval(checkIdentity), 10000);
      }

      // 2. SMOOTH REDIRECTS
      // If they just confirmed their email in this tab, send them to admin
      window.netlifyIdentity.on("confirmation", () => {
        document.location.href = "/admin/";
      });

      // If they log in normally, send them to admin
      window.netlifyIdentity.on("login", () => {
        document.location.href = "/admin/";
      });

	  // Add this right after the "login" block (around line 50)
window.netlifyIdentity.on("close", () => {
  const user = window.netlifyIdentity.currentUser();
  if (user) {
    document.location.href = "/admin/";
  }
});

    }
  }

  // Run on initial load
  handleIdentity();
  // Run on Astro page swaps
  document.addEventListener('astro:after-swap', handleIdentity);
</script>

	</body>
</html>








