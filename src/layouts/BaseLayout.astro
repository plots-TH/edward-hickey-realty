---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { ClientRouter } from 'astro:transitions';

const { title = "Edward Hickey | Real Estate" } = Astro.props;
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title}</title>

		<!-- 1. The ONLY library call - no extra logic here -->
		<script is:inline src="/netlify-identity.js"></script>

		<ClientRouter />

		<!-- SEO & Favicon -->
		<meta name="description" content="Edward Hickey - Luxury Real Estate Associate Broker at Compass." />
		<link rel="icon" type="image/png" href="/favicon.png" />
	</head>
	<body class="bg-white text-slate-900 flex flex-col min-h-screen">
		<Header />
		<main class="flex-grow">
			<slot />
		</main>
		<Footer />

		<!-- 2. The script that FORCES the signup box to open -->
		<script is:inline>
    function handleIdentity() {
    if (!window.netlifyIdentity) return;

    // 1. WATCHDOG: Redirect this tab if we log in anywhere
    const checkLogin = () => {
      if (window.netlifyIdentity.currentUser()) {
        document.location.href = "/admin/";
      }
    };

    // 2. CROSS-TAB SYNC: Listen for the login cookie from the other tab
    window.addEventListener('storage', (event) => {
      if (event.key === 'netlify-cms-user' || event.key.includes('gotrue.user')) {
        checkLogin();
      }
    });

    // 3. INTERNAL EVENTS: Handle logic within this specific tab
    window.netlifyIdentity.on("init", user => {
      if (user) return checkLogin();
      if (window.location.hash.includes("invite_token")) {
        window.netlifyIdentity.open("signup");
      }
    });

    window.netlifyIdentity.on("login", () => {
      // If we are the "New" tab (the email link), close ourselves
      if (window.opener) {
        window.close();
      } else {
        checkLogin();
      }
    });
    
    // Fallback check
    setInterval(checkLogin, 2000);
  }

  handleIdentity();
  document.addEventListener('astro:page-load', handleIdentity);

</script>

</body>
</html>









