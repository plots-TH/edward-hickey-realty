---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { ClientRouter } from 'astro:transitions';

const { title = "Edward Hickey | Real Estate" } = Astro.props;
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title}</title>

		<!-- 1. The Widget must be the FIRST thing in the head -->
		</script>

		<ClientRouter />

		<meta name="description" content="Edward Hickey - Luxury Real Estate Associate Broker at Compass." />
		<link rel="icon" type="image/png" href="/favicon.png" />
	</head>
	<body class="bg-white text-slate-900 flex flex-col min-h-screen">
		<Header />
		<main class="flex-grow">
			<slot />
		</main>
		<Footer />

		<!-- 2. This script runs at the BOTTOM to handle the invite pop-up -->
<script is:inline>
  // This function handles the logic
  function initIdentity() {
    if (window.netlifyIdentity) {
      // 1. Listen for the 'init' event - this is the most reliable way
      window.netlifyIdentity.on("init", user => {
        if (!user) {
          // If there's an invite token in the URL, force the signup modal
          if (window.location.hash.includes("invite_token")) {
            window.netlifyIdentity.open("signup");
          }
          
          // Handle redirect after they eventually set their password/login
          window.netlifyIdentity.on("login", () => {
            document.location.href = "/admin/";
          });
        }
      });
    }
  }

  // Run immediately
  initIdentity();
  
  // Re-run for Astro's ClientRouter navigation
  document.addEventListener('astro:page-load', initIdentity);
</script>

	</body>
</html>
