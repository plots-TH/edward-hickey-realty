		
		</script>
		
		
		<script is:inline>
			function handleIdentity() {
				if (window.netlifyIdentity) {
					// 1. Handle normal login redirects
					window.netlifyIdentity.on("init", (user) => {
						if (!user) {
							window.netlifyIdentity.on("login", () => {
								document.location.href = "/admin/";
							});
						}
					});

					// 2. FORCE opening the signup modal if an invite token is present
					const hash = window.location.hash;
					if (hash && hash.includes("invite_token")) {
						// Small timeout to let the widget fully initialize
						setTimeout(() => {
							window.netlifyIdentity.open("signup");
						}, 500);
					}
				}
			}

			// Run on load
			handleIdentity();
			// Re-run for Astro's ClientRouter navigation
			document.addEventListener('astro:page-load', handleIdentity);
		</script>





