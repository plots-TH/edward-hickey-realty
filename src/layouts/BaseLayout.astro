---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { ClientRouter } from 'astro:transitions';

const { title = "Edward Hickey | Real Estate" } = Astro.props;
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title}</title>

		
		<script is:inline src={"https://identity"+"."+"netlify"+"."+"com/v1/netlify-identity-widget.js"}></script>

		<ClientRouter />

		<!-- SEO & Social Sharing -->
		<meta name="description" content="Edward Hickey - Luxury Real Estate Associate Broker at Compass. Specializing in bespoke Manhattan property portfolios." />
		<meta property="og:title" content={title} />
		<meta property="og:type" content="website" />
		<meta property="og:image" content="/favicon.png" />

		<!-- Favicon -->
		<link rel="icon" type="image/png" href="/favicon.png" />
	</head>
	<body class="bg-white text-slate-900 flex flex-col min-h-screen overflow-x-hidden">
		<Header />
		<main class="flex-grow">
			<slot />
		</main>
		<Footer />

		
		<script is:inline>
  function runIdentity() {
    if (window.netlifyIdentity) {
      // 1. Force the widget to stay "anchored" to your specific site
      window.netlifyIdentity.on("init", user => {
        if (!user) {
          // 2. Handle invite tokens immediately
          if (window.location.hash.includes("invite_token")) {
            window.netlifyIdentity.open("signup");
          }
          // 3. Ensure login always triggers the admin redirect
          window.netlifyIdentity.on("login", () => {
            document.location.href = "/admin/";
          });
        }
      });
    }
  }

  // Initial run
  runIdentity();
  
  // The secret sauce: Re-run every time Astro "swaps" pages
  document.addEventListener('astro:page-load', () => {
    setTimeout(runIdentity, 500); 
  });
</script>


	</body>
</html>






