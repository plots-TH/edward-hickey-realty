---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { ClientRouter } from 'astro:transitions';

const { title = "Edward Hickey | Real Estate" } = Astro.props;
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title}</title>

		
		</script>

		<ClientRouter />

		<!-- SEO & Social Sharing -->
		<meta name="description" content="Edward Hickey - Luxury Real Estate Associate Broker at Compass. Specializing in bespoke Manhattan property portfolios and market insights." />
		<meta property="og:title" content={title} />
		<meta property="og:description" content="Edward Hickey - Luxury Real Estate Associate Broker at Compass." />
		<meta property="og:image" content="/favicon.png" />
		<meta property="og:type" content="website" />

		<!-- Favicon -->
		<link rel="icon" type="image/png" href="/favicon.png" />

		<!-- 2. The script that handles the login redirect -->
		<script is:inline>
			if (window.netlifyIdentity) {
				window.netlifyIdentity.on("init", (user) => {
					if (!user) {
						window.netlifyIdentity.on("login", () => {
							document.location.href = "/admin/";
						});
					}
				});
			}
		</script>
	</head>
	<body class="bg-white text-slate-900 flex flex-col min-h-screen overflow-x-hidden">
		<Header />
		<main class="flex-grow">
			<slot />
		</main>
		<Footer />
	</body>
</html>




