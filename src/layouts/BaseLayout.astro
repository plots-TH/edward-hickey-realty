---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { ClientRouter } from 'astro:transitions';

const { title = "Edward Hickey | Real Estate" } = Astro.props;
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title}</title>
		
		<!-- 1. LOAD WIDGET IMMEDIATELY -->
		</script>

		<ClientRouter />

		<!-- SEO & Social Sharing -->
		<meta name="description" content="Edward Hickey - Luxury Real Estate Associate Broker at Compass." />
		<link rel="icon" type="image/png" href="/favicon.png" />
	</head>
	<body class="bg-white text-slate-900 flex flex-col min-h-screen">
		<Header />
		<main class="flex-grow">
			<slot />
		</main>
		<Footer />

		<!-- 2. FORCED TRIGGER SCRIPT -->
		<script is:inline>
			function forceIdentityModal() {
				if (window.netlifyIdentity) {
					// Handle the redirect after login
					window.netlifyIdentity.on("login", () => {
						document.location.href = "/admin/";
					});

					// BRUTE FORCE: If there is a token, keep trying to open the modal
					if (window.location.hash.includes("invite_token")) {
						let attempts = 0;
						const checkExist = setInterval(() => {
							attempts++;
							window.netlifyIdentity.open("signup");
							
							// Stop trying after 5 seconds or if modal appears
							if (attempts > 10) {
								clearInterval(checkExist);
							}
						}, 500);
					}
				}
			}

			// Run on initial load and every time ClientRouter swaps a page
			forceIdentityModal();
			document.addEventListener('astro:page-load', forceIdentityModal);
		</script>
	</body>
</html>


