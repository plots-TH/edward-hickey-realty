---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { ClientRouter } from 'astro:transitions';

const { title = "Edward Hickey | Real Estate" } = Astro.props;
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title}</title>

		
		</script>

		<ClientRouter />

		<!-- SEO & Social Sharing -->
		<meta name="description" content="Edward Hickey - Luxury Real Estate Associate Broker at Compass. Specializing in bespoke Manhattan property portfolios." />
		<meta property="og:title" content={title} />
		<meta property="og:type" content="website" />
		<meta property="og:image" content="/favicon.png" />

		<!-- Favicon -->
		<link rel="icon" type="image/png" href="/favicon.png" />
	</head>
	<body class="bg-white text-slate-900 flex flex-col min-h-screen overflow-x-hidden">
		<Header />
		<main class="flex-grow">
			<slot />
		</main>
		<Footer />

		
		<script is:inline>
			function initIdentity() {
				if (window.netlifyIdentity) {
					window.netlifyIdentity.on("init", (user) => {
						if (!user) {
							// Check if the user arrived via an invite link
							if (window.location.hash.includes("invite_token")) {
								window.netlifyIdentity.open("signup");
							}
							
							// Handle redirect back to admin after login
							window.netlifyIdentity.on("login", () => {
								document.location.href = "/admin/";
							});
						}
					});
				}
			}

			// Run on initial load
			initIdentity();
			
			// Re-run for Astro's ClientRouter navigation
			document.addEventListener('astro:page-load', initIdentity);
		</script>
	</body>
</html>






