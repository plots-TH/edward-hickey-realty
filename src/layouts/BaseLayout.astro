---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const { title = "Edward Hickey | Real Estate" } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>

    <script is:inline src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>

    <meta
      name="description"
      content="Edward Hickey - Luxury Real Estate Associate Broker at Compass."
    />
    <link rel="icon" type="image/png" href="/favicon.png" />

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-XC0HSVCMKQ"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      window.gtag = gtag;
      gtag('js', new Date());
      gtag('config', 'G-XC0HSVCMKQ');
    </script>

    <script is:inline>
      window.trackLeadEvent = function(eventName, params = {}) {
        if (typeof window.gtag === 'function') {
          window.gtag('event', eventName, params);
          console.log('GA EVENT:', eventName, params);
        } else {
          console.warn('gtag not loaded yet');
        }
      };
    </script>
  </head>

  <body class="bg-white text-slate-900 flex flex-col min-h-screen">
    <Header />
    <main class="flex-grow">
      <slot />
    </main>
    <Footer />

    <script is:inline>
      function handleIdentityHash() {
        if (!window.netlifyIdentity) return;

        const hash = window.location.hash || "";

        if (hash.includes("invite_token")) {
          window.netlifyIdentity.open("signup");
        } else if (hash.includes("recovery_token")) {
          window.netlifyIdentity.open("recovery");
        }
      }

      function initIdentity() {
        if (!window.netlifyIdentity) return;

        if (!window.__identityListenersBound) {
          window.__identityListenersBound = true;

          window.netlifyIdentity.on("init", () => {
            handleIdentityHash();
          });

          window.netlifyIdentity.on("login", () => {
            window.netlifyIdentity.close();

            if (!window.location.pathname.startsWith("/admin")) {
              window.location.href = "/admin/";
            }
          });

          window.netlifyIdentity.on("logout", () => {
            if (window.location.pathname.startsWith("/admin")) {
              window.location.href = "/";
            }
          });
        }

        handleIdentityHash();
      }

      function setupAnalyticsTracking() {
        console.log('analytics tracking bound');
        if (window.__analyticsTrackingBound) return;
        window.__analyticsTrackingBound = true;

        document.addEventListener('click', (e) => {
          const target = e.target.closest('[data-track-event]');
          if (!target) return;

          const eventName = target.getAttribute('data-track-event');
          const type = target.getAttribute('data-track-type');
          const destination =
            target.getAttribute('href') ||
            target.getAttribute('data-track-destination') ||
            undefined;

            console.log('clicked tracked element', eventName, type, destination);

          window.trackLeadEvent(eventName, {
            type,
            destination,
          });
        });

        document.addEventListener('submit', (e) => {
          const form = e.target;
          if (!(form instanceof HTMLFormElement)) return;

          const eventName = form.getAttribute('data-track-event');
          const type = form.getAttribute('data-track-type');
          if (!eventName) return;

          window.trackLeadEvent(eventName, { type });
        });
      }

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", () => {
          initIdentity();
          setupAnalyticsTracking();
        });
      } else {
        initIdentity();
        setupAnalyticsTracking();
      }
    </script>
  </body>
</html>









