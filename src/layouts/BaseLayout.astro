---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { ClientRouter } from 'astro:transitions';

const { title = "Edward Hickey | Real Estate" } = Astro.props;
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title}</title>

		<!-- 1. The ONLY library call - no extra logic here -->
		<script is:inline src="/netlify-identity.js"></script>

		<ClientRouter />

		<!-- SEO & Favicon -->
		<meta name="description" content="Edward Hickey - Luxury Real Estate Associate Broker at Compass." />
		<link rel="icon" type="image/png" href="/favicon.png" />
	</head>
	<body class="bg-white text-slate-900 flex flex-col min-h-screen">
		<Header />
		<main class="flex-grow">
			<slot />
		</main>
		<Footer />

		<!-- 2. The script that FORCES the signup box to open -->
		<script is:inline>
  function initIdentity() {
    if (window.netlifyIdentity) {
      // 1. Listen for the initial "Handshake"
      window.netlifyIdentity.on("init", (user) => {
        if (!user && window.location.hash.includes("invite_token")) {
          window.netlifyIdentity.open("signup");
        }
      });

      // 2. ONLY redirect when a login actually happens
      window.netlifyIdentity.on("login", () => {
        document.location.href = "/admin/";
      });

      // 3. Clean up on logout to prevent "User Not Found" errors
      window.netlifyIdentity.on("logout", () => {
        localStorage.clear();
        document.location.href = "/";
      });
    }
  }

  // Run once on load
  initIdentity();
  // Support Astro page transitions
  document.addEventListener('astro:page-load', initIdentity);
</script>


</body>
</html>









