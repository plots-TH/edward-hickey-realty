---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { ClientRouter } from 'astro:transitions';

const { title = "Edward Hickey | Real Estate" } = Astro.props;
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title}</title>

		<!-- 1. The ACTUAL Library - Critical to have this here -->
		</script>

		<ClientRouter />

		<meta name="description" content="Edward Hickey - Luxury Real Estate Associate Broker at Compass." />
		<link rel="icon" type="image/png" href="/favicon.png" />
	</head>
	<body class="bg-white text-slate-900 flex flex-col min-h-screen">
		<Header />
		<main class="flex-grow">
			<slot />
		</main>
		<Footer />

		<!-- 2. Logic to catch the invite token and open the password modal -->
		<script is:inline>
			function initIdentity() {
				if (window.netlifyIdentity) {
					window.netlifyIdentity.on("init", user => {
						if (!user) {
							// Check if the URL contains the invite token
							if (window.location.hash.includes("invite_token")) {
								// Open the signup/password creation modal immediately
								window.netlifyIdentity.open("signup");
							}
							
							// Redirect to admin after they finish setting the password
							window.netlifyIdentity.on("login", () => {
								document.location.href = "/admin/";
							});
						}
					});
				}
			}

			// Run on initial page load
			initIdentity();
			
			// Re-run for Astro's ClientRouter navigation so it works on back/forward
			document.addEventListener('astro:page-load', initIdentity);
		</script>
	</body>
</html>

